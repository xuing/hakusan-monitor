# Hakusan Monitor — local config. Copy to `.env` and fill in your own values.
#   cp .env.example .env
# `.env` is gitignored, so your SSH user / student ID never gets committed.
# The backend loads .env at startup; docker-compose and the systemd unit read it too.
# Real environment variables (export / systemd / docker) override these.

# SSH target for HM_SOURCE=ssh — YOUR account on the login node.
# Comma-separated preference list: each cycle tries hosts in order,
# so the primary is restored automatically once it answers again.
HM_SSH_HOST=you@hakusan2,you@hakusan1

# Optional: monitor both login nodes' own health (load, memory, disk, top processes).
# Format: display-name=ssh-target,display-name=ssh-target
HM_LOGIN_NODES=hakusan1=you@hakusan1,hakusan2=you@hakusan2

# Data source: ssh | local | mock   (mock serves the bundled demo fixtures)
HM_SOURCE=ssh

# Sampling cadence in seconds (default 300 = 5 min; be gentle on the login node).
# HM_SAMPLE_INTERVAL=300
# HM_SOURCE_TIMEOUT=75

# Login-node health cadence and process list size.
# HM_LOGIN_INTERVAL=300
# HM_LOGIN_TOP_N=12
# HM_LOGIN_SHOW_ARGS=0
# HM_LOGIN_TIMEOUT=25

# SQLite retention windows. Cluster and login-node samples default to 60 days;
# anonymous daily visit counters default to 365 days.
# HM_RETAIN_DAYS=60
# HM_LOGIN_RETAIN_DAYS=60
# HM_VISIT_RETAIN_DAYS=365

# Listen port.
# HM_PORT=8787

# Only trust X-Forwarded-For when a trusted reverse proxy overwrites it.
# HM_TRUST_PROXY=0
# Enable the standard HTTP request log (off by default).
# HM_ACCESS_LOG=0

# Anonymize usernames in the public view (1 = on).
# HM_MASK_USERS=0
